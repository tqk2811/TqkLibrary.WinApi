<Project>
	<!-- Emit XML doc (IntelliSense) for every packable project; CS1591 = missing doc comment. -->
	<PropertyGroup>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<NoWarn>$(NoWarn);CS1591</NoWarn>
	</PropertyGroup>

	<!--
		GitVersion wiring for NuGet packaging.

		Version scheme (tag vMAJOR.MINOR.0, e.g. v1.0.0):
		  Version / PackageVersion = Major.Minor.<commits since tag>     (NuGet version)
		  AssemblyVersion          = Major.Minor.0.0
		  FileVersion              = Major.Minor.<commits since tag>.0

		- Only projects with a sibling <ProjectName>.nuspec get GitVersion wired
		  (test/demo projects without a nuspec skip the whole chain).
		- Debug skips GitVersion entirely so feature/branch builds don't fail when the
		  branch isn't covered by GitVersion.yml; version is hard-coded so MSBuild's
		  NETSDK1018 ('.' invalid) doesn't fire when GitVersion outputs are empty.
		  Release goes through GitVersion and produces the real version.
		- DisableGitVersionTask alone only skips RunGitVersion/GetVersion; the other
		  GitVersion targets still try to read obj/gitversion.json, so turn them all off.
	-->
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<Deterministic>true</Deterministic>
		<ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
		<!-- Embed all source files into the portable PDB so step-into works offline;
		     Deterministic + ContinuousIntegrationBuild normalize source paths in the PDB. -->
		<EmbedAllSources>true</EmbedAllSources>
	</PropertyGroup>

	<PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)\$(MSBuildProjectName).nuspec')">
		<NuspecFile>$(MSBuildProjectName).nuspec</NuspecFile>
		<EnableGitVersion>true</EnableGitVersion>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Debug' and '$(EnableGitVersion)' == 'true'">
		<DisableGitVersionTask>true</DisableGitVersionTask>
		<WriteVersionInfoToBuildLog>false</WriteVersionInfoToBuildLog>
		<GenerateGitVersionInformation>false</GenerateGitVersionInformation>
		<UpdateAssemblyInfo>false</UpdateAssemblyInfo>
		<GenerateGitVersionFiles>false</GenerateGitVersionFiles>
		<Version>0.0.0-debug</Version>
		<PackageVersion>0.0.0-debug</PackageVersion>
	</PropertyGroup>

	<ItemGroup Condition="'$(EnableGitVersion)' == 'true'">
		<PackageReference Include="GitVersion.MsBuild" Version="6.7.0">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<Target Name="SetVersionFromGitVersion" AfterTargets="GetVersion" Condition="'$(EnableGitVersion)' == 'true' and '$(DisableGitVersionTask)' != 'true'">
		<PropertyGroup>
			<Version>$(GitVersion_Major).$(GitVersion_Minor).$(GitVersion_CommitsSinceVersionSource)</Version>
			<PackageVersion>$(Version)</PackageVersion>
			<AssemblyVersion>$(GitVersion_Major).$(GitVersion_Minor).0.0</AssemblyVersion>
			<FileVersion>$(GitVersion_Major).$(GitVersion_Minor).$(GitVersion_CommitsSinceVersionSource).0</FileVersion>
			<InformationalVersion>$(Version)</InformationalVersion>
			<NuspecProperties>id=$(MSBuildProjectName);version=$(Version)</NuspecProperties>
		</PropertyGroup>
	</Target>
</Project>
